{
  "targets": [
    {
      "file": "protected/command_deck.html",
      "ops": [
        {
          "kind": "strictInsertOnce",
          "markerBegin": "<!-- GX:MAP:ASSETS:BEGIN -->",
          "markerEnd": "<!-- GX:MAP:ASSETS:END -->",
          "insertBody": "<link rel=\"stylesheet\" href=\"../components/gx-map/gx-map.css?v=${BUILD_TAG}\">\n<script defer src=\"../components/gx-map/gx-map.js?v=${BUILD_TAG}\"></script>"
        },
        {
          "kind": "strictInsertOnce",
          "markerBegin": "<!-- GX:MAP:BEGIN -->",
          "markerEnd": "<!-- GX:MAP:END -->",
          "insertBody": "<section class=\"gx-map-shell\" aria-label=\"Interactive ecosystem map\">\n  <h2 class=\"gx-map-title\">Ecosystem Map</h2>\n\n  <div\n    class=\"gx-map\"\n    data-gx-map\n    data-gx-map-min-scale=\"0.25\"\n    data-gx-map-max-scale=\"6\"\n    data-gx-map-zoom-step=\"1.2\"\n    data-gx-map-pan-step=\"64\"\n  >\n    <div class=\"gx-map__toolbar\" role=\"toolbar\" aria-label=\"Map controls\">\n      <button type=\"button\" class=\"gx-map__btn\" data-gx-map-zoom-in aria-label=\"Zoom in\">+</button>\n      <button type=\"button\" class=\"gx-map__btn\" data-gx-map-zoom-out aria-label=\"Zoom out\">−</button>\n      <button type=\"button\" class=\"gx-map__btn\" data-gx-map-fit aria-label=\"Fit to view\">Fit</button>\n      <button type=\"button\" class=\"gx-map__btn\" data-gx-map-reset aria-label=\"Reset view\">Reset</button>\n      <button type=\"button\" class=\"gx-map__btn\" data-gx-map-help aria-label=\"Keyboard and gesture help\">Help</button>\n    </div>\n\n    <div\n      class=\"gx-map__viewport\"\n      tabindex=\"0\"\n      role=\"region\"\n      aria-label=\"Interactive map viewport\"\n      aria-describedby=\"gx-map-help gx-map-status\"\n    >\n      <div class=\"gx-map__content\" aria-label=\"Map content\">\n        <svg class=\"gx-map__svg\" viewBox=\"0 0 1600 1000\" role=\"img\" aria-label=\"GRACE-X map diagram\">\n          <defs>\n            <filter id=\"glowGold\" x=\"-20%\" y=\"-20%\" width=\"140%\" height=\"140%\">\n              <feGaussianBlur stdDeviation=\"12\" result=\"blur\" />\n              <feComposite in=\"SourceGraphic\" in2=\"blur\" operator=\"over\" />\n            </filter>\n            <filter id=\"glowBlue\" x=\"-20%\" y=\"-20%\" width=\"140%\" height=\"140%\">\n              <feGaussianBlur stdDeviation=\"16\" result=\"blur\" />\n              <feComposite in=\"SourceGraphic\" in2=\"blur\" operator=\"over\" />\n            </filter>\n            <filter id=\"glowPurple\" x=\"-20%\" y=\"-20%\" width=\"140%\" height=\"140%\">\n              <feGaussianBlur stdDeviation=\"16\" result=\"blur\" />\n              <feComposite in=\"SourceGraphic\" in2=\"blur\" operator=\"over\" />\n            </filter>\n            <filter id=\"glowGreen\" x=\"-20%\" y=\"-20%\" width=\"140%\" height=\"140%\">\n              <feGaussianBlur stdDeviation=\"8\" result=\"blur\" />\n              <feComposite in=\"SourceGraphic\" in2=\"blur\" operator=\"over\" />\n            </filter>\n\n            <linearGradient id=\"gradGold\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\">\n              <stop offset=\"0%\" stop-color=\"#fff9de\" />\n              <stop offset=\"40%\" stop-color=\"#f4d03f\" />\n              <stop offset=\"100%\" stop-color=\"#a27916\" />\n            </linearGradient>\n            <linearGradient id=\"gradBlue\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\">\n              <stop offset=\"0%\" stop-color=\"#e8f9ff\" />\n              <stop offset=\"40%\" stop-color=\"#61c8ff\" />\n              <stop offset=\"100%\" stop-color=\"#0b5d80\" />\n            </linearGradient>\n            <linearGradient id=\"gradPurple\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\">\n              <stop offset=\"0%\" stop-color=\"#f6e6ff\" />\n              <stop offset=\"40%\" stop-color=\"#c864ff\" />\n              <stop offset=\"100%\" stop-color=\"#64158c\" />\n            </linearGradient>\n            <linearGradient id=\"gradGreen\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\">\n              <stop offset=\"0%\" stop-color=\"#f1fff6\" />\n              <stop offset=\"40%\" stop-color=\"#8dffb3\" />\n              <stop offset=\"100%\" stop-color=\"#2a7e4a\" />\n            </linearGradient>\n\n            <linearGradient id=\"linkEyeCore2\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"0%\">\n              <stop offset=\"0%\" stop-color=\"#f4d03f\" />\n              <stop offset=\"100%\" stop-color=\"#61c8ff\" />\n            </linearGradient>\n            <linearGradient id=\"linkEyeCore3\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"0%\">\n              <stop offset=\"0%\" stop-color=\"#f4d03f\" />\n              <stop offset=\"100%\" stop-color=\"#c864ff\" />\n            </linearGradient>\n            \n            <style>\n              .bg-panel { fill: rgba(10,16,28,0.6); stroke: #1a253c; stroke-width: 2; rx: 24px; ry: 24px; pointer-events: none;}\n              .bg-panel-title { fill: #6a7c9d; font: 700 20px system-ui, sans-serif; letter-spacing: 0.2em; text-transform: uppercase; pointer-events: none;}\n              .l-gold { stroke: #f4d03f; stroke-width: 3; opacity: 0.6; fill: none; stroke-dasharray: 6 6; animation: dash 20s linear infinite; }\n              .l-blue { stroke: #61c8ff; stroke-width: 2; opacity: 0.5; fill: none; }\n              .l-purple { stroke: #c864ff; stroke-width: 2; opacity: 0.5; fill: none; }\n              .l-green { stroke: #8dffb3; stroke-width: 2; opacity: 0.5; fill: none; }\n              .t-title { fill: #ffffff; font: 800 24px system-ui, sans-serif; letter-spacing: 0.1em; pointer-events: none;}\n              .t-sub { fill: #9aabca; font: 600 13px system-ui, sans-serif; letter-spacing: 0.05em; pointer-events: none;}\n              \n              @keyframes dash {\n                to { stroke-dashoffset: -1000; }\n              }\n              .node-core { cursor: pointer; transition: transform 0.3s ease; }\n              .node-core:hover { transform: scale(1.05); }\n            </style>\n          </defs>\n\n          <!-- Background Grids/Panels -->\n          <rect x=\"80\" y=\"160\" width=\"1440\" height=\"720\" class=\"bg-panel\" />\n          \n          <rect x=\"120\" y=\"240\" width=\"380\" height=\"580\" class=\"bg-panel\" />\n          <text x=\"150\" y=\"280\" class=\"bg-panel-title\">Security &amp; Routing</text>\n          \n          <rect x=\"540\" y=\"240\" width=\"520\" height=\"580\" class=\"bg-panel\" />\n          <text x=\"570\" y=\"280\" class=\"bg-panel-title\">Orchestration &amp; Master Core</text>\n\n          <rect x=\"1100\" y=\"240\" width=\"380\" height=\"580\" class=\"bg-panel\" />\n          <text x=\"1130\" y=\"280\" class=\"bg-panel-title\">Synthesis &amp; Output</text>\n\n          <!-- Connections -->\n          <path d=\"M 800 360 L 310 500\" class=\"l-gold\" stroke=\"url(#linkEyeCore2)\" />\n          <path d=\"M 800 360 L 1290 500\" class=\"l-gold\" stroke=\"url(#linkEyeCore3)\" />\n          \n          <path d=\"M 310 500 L 240 680\" class=\"l-blue\" />\n          <path d=\"M 310 500 L 380 680\" class=\"l-blue\" />\n          <path d=\"M 310 500 L 180 500\" class=\"l-blue\" />\n          \n          <path d=\"M 1290 500 L 1220 680\" class=\"l-purple\" />\n          <path d=\"M 1290 500 L 1360 680\" class=\"l-purple\" />\n          <path d=\"M 1290 500 L 1420 500\" class=\"l-purple\" />\n\n          <path d=\"M 800 360 L 800 680\" class=\"l-green\" />\n\n          <!-- Nodes -->\n          <g class=\"node-core\" transform=\"translate(800, 360)\" style=\"transform-origin: 800px 360px\">\n            <circle r=\"75\" fill=\"none\" stroke=\"#f4d03f\" stroke-width=\"2\" stroke-opacity=\"0.2\" />\n            <circle r=\"60\" fill=\"url(#gradGold)\" filter=\"url(#glowGold)\" />\n            <text y=\"5\" text-anchor=\"middle\" fill=\"#000\" font-family=\"system-ui, sans-serif\" font-weight=\"900\" font-size=\"22\" letter-spacing=\"0.1em\" style=\"pointer-events:none\">THE EYE</text>\n            <text y=\"110\" text-anchor=\"middle\" class=\"t-title\">Central</text>\n            <text y=\"135\" text-anchor=\"middle\" class=\"t-sub\">Master Orchestrator</text>\n          </g>\n\n          <g class=\"node-core\" transform=\"translate(310, 500)\" style=\"transform-origin: 310px 500px\">\n            <circle r=\"65\" fill=\"none\" stroke=\"#61c8ff\" stroke-width=\"2\" stroke-opacity=\"0.2\" />\n            <circle r=\"50\" fill=\"url(#gradBlue)\" filter=\"url(#glowBlue)\" />\n            <text y=\"5\" text-anchor=\"middle\" fill=\"#fff\" font-family=\"system-ui, sans-serif\" font-weight=\"900\" font-size=\"20\" letter-spacing=\"0.1em\" style=\"pointer-events:none\">CORE 2</text>\n            <text y=\"95\" text-anchor=\"middle\" class=\"t-title\">Analytics Engine</text>\n            <text y=\"120\" text-anchor=\"middle\" class=\"t-sub\">Inspection &amp; Security</text>\n          </g>\n\n          <g class=\"node-core\" transform=\"translate(1290, 500)\" style=\"transform-origin: 1290px 500px\">\n            <circle r=\"65\" fill=\"none\" stroke=\"#c864ff\" stroke-width=\"2\" stroke-opacity=\"0.2\" />\n            <circle r=\"50\" fill=\"url(#gradPurple)\" filter=\"url(#glowPurple)\" />\n            <text y=\"5\" text-anchor=\"middle\" fill=\"#fff\" font-family=\"system-ui, sans-serif\" font-weight=\"900\" font-size=\"20\" letter-spacing=\"0.1em\" style=\"pointer-events:none\">CORE 3</text>\n            <text y=\"95\" text-anchor=\"middle\" class=\"t-title\">Processing Engine</text>\n            <text y=\"120\" text-anchor=\"middle\" class=\"t-sub\">Synthesis &amp; Response</text>\n          </g>\n\n          <!-- Security Modules -->\n          <g transform=\"translate(180, 500)\">\n            <circle r=\"20\" fill=\"url(#gradBlue)\" />\n            <text x=\"-35\" y=\"5\" text-anchor=\"end\" class=\"t-title\" font-size=\"16\">SENTINEL</text>\n          </g>\n          <g transform=\"translate(240, 680)\">\n            <circle r=\"30\" fill=\"url(#gradBlue)\" />\n            <text y=\"55\" text-anchor=\"middle\" class=\"t-title\" font-size=\"16\">TITAN</text>\n            <text y=\"75\" text-anchor=\"middle\" class=\"t-sub\">Threat Analysis</text>\n          </g>\n          <g transform=\"translate(380, 680)\">\n            <circle r=\"30\" fill=\"url(#gradBlue)\" />\n            <text y=\"55\" text-anchor=\"middle\" class=\"t-title\" font-size=\"16\">VENUS</text>\n            <text y=\"75\" text-anchor=\"middle\" class=\"t-sub\">Boundary</text>\n          </g>\n\n          <!-- Output Modules -->\n          <g transform=\"translate(1420, 500)\">\n            <circle r=\"20\" fill=\"url(#gradPurple)\" />\n            <text x=\"35\" y=\"5\" text-anchor=\"start\" class=\"t-title\" font-size=\"16\">UPLIFT</text>\n          </g>\n          <g transform=\"translate(1220, 680)\">\n            <circle r=\"30\" fill=\"url(#gradPurple)\" />\n            <text y=\"55\" text-anchor=\"middle\" class=\"t-title\" font-size=\"16\">CHEF</text>\n            <text y=\"75\" text-anchor=\"middle\" class=\"t-sub\">Culinary Logic</text>\n          </g>\n          <g transform=\"translate(1360, 680)\">\n            <circle r=\"30\" fill=\"url(#gradPurple)\" />\n            <text y=\"55\" text-anchor=\"middle\" class=\"t-title\" font-size=\"16\">ARTIST</text>\n            <text y=\"75\" text-anchor=\"middle\" class=\"t-sub\">Creative Output</text>\n          </g>\n\n          <!-- Infrastructure -->\n          <g transform=\"translate(800, 680)\">\n            <circle r=\"25\" fill=\"url(#gradGreen)\" filter=\"url(#glowGreen)\" />\n            <text y=\"50\" text-anchor=\"middle\" class=\"t-title\" font-size=\"16\">ROUTER &amp; VAULT</text>\n            <text y=\"70\" text-anchor=\"middle\" class=\"t-sub\">Persistent Memory</text>\n          </g>\n        </svg>\n      </div>\n    </div>\n\n    <p id=\"gx-map-help\" class=\"gx-sr-only\">\n      Map controls: Drag to pan; pinch to zoom; double-tap or double-click to zoom in.\n      Keyboard: Arrow keys pan; plus/equal zoom in; minus zoom out; 0 resets; F fits to view.\n    </p>\n\n    <div id=\"gx-map-status\" class=\"gx-map__status\" aria-live=\"polite\"></div>\n  </div>\n</section>"
        }
      ],
      "guardrail": {
        "mustContain": [
          "components/gx-map/gx-map.css?v=${BUILD_TAG}",
          "components/gx-map/gx-map.js?v=${BUILD_TAG}",
          "data-gx-map"
        ],
        "forbidHttpInFile": false
      }
    }
  ]
}